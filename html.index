<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Conteúdo Exclusivo</title>

<style>
    body {
        margin: 0;
        padding: 0;
        background: #0b0b0b;
        font-family: Arial, sans-serif;
        color: white;
        display: flex;
        justify-content: center;
        align-items: center;
        height: 100vh;
    }

    .container {
        width: 90%;
        max-width: 400px;
        background: #111;
        border: 2px solid #ff003c;
        border-radius: 20px;
        padding: 20px;
        text-align: center;
        box-shadow: 0 0 25px rgba(255, 0, 60, 0.5);
    }

    .banner {
        width: 100%;
        border-radius: 15px;
        margin-bottom: 20px;
    }

    .title {
        font-size: 22px;
        font-weight: bold;
        color: #ff2e63;
        margin-bottom: 10px;
    }

    .subtitle {
        font-size: 14px;
        color: #ccc;
        margin-bottom: 25px;
    }

    .cta-text {
        font-size: 16px;
        font-weight: bold;
        color: #ff4d6d;
        margin-bottom: 15px;
        animation: pulse 1.5s infinite;
    }

    @keyframes pulse {
        0% { opacity: 1; }
        50% { opacity: 0.5; }
        100% { opacity: 1; }
    }

    .btn {
        display: inline-block;
        width: 100%;
        padding: 15px;
        background: linear-gradient(45deg, #ff003c, #ff5e78);
        color: white;
        font-size: 18px;
        font-weight: bold;
        text-decoration: none;
        border-radius: 30px;
        transition: 0.3s;
    }

    .btn:hover {
        transform: scale(1.05);
        box-shadow: 0 0 15px #ff003c;
    }

    .footer {
        margin-top: 15px;
        font-size: 12px;
        color: #888;
    }
</style>

</head>
<body>

<div class="container">

    <!-- COLOQUE SEU BANNER AQUI -->
    <img src="SEU-BANNER-AQUI.jpg" class="banner">

    <div class="title">CONTEÚDO EXCLUSIVO 🔥</div>
    <div class="subtitle">Acesso liberado apenas para membros selecionados</div>

    <div class="cta-text">ÚLTIMAS VAGAS DO DIA</div>

    <a href="https://t.me/+vD9cMclPoyplOWVh" class="btn">
        ENTRAR AGORA →
    </a>

    <div class="footer">Conteúdo para maiores de 18 anos</div>

</div>

</body>
</html>
